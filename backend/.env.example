# Copy to .env and fill in your own values
# Electricity tariff used by the cost calculator
ELECTRICITY_USD_PER_KWH=0.12
# PUE target (lower = more efficient; 1.30 is best-in-class for enterprise DCs)
TARGET_PUE=1.30
# For projecting savings to a full facility in the pitch
NUM_RACKS_SCALE=100
# Anthropic API key — only needed if you enable Claude-powered incident summaries later
# ANTHROPIC_API_KEY=sk-ant-xxx
